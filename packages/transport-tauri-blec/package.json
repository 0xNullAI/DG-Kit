{
  "name": "@dg-kit/transport-tauri-blec",
  "version": "1.0.0",
  "description": "Tauri Android/iOS DeviceClient for DG-Lab Coyote (BLE via @mnlphlp/plugin-blec)",
  "license": "MIT",
  "author": "0xNullAI",
  "homepage": "https://github.com/0xNullAI/DG-Kit/tree/main/packages/transport-tauri-blec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xNullAI/DG-Kit.git",
    "directory": "packages/transport-tauri-blec"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
